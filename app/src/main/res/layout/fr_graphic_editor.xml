<?xml version="1.0" encoding="utf-8" ?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Sidebar Container -->
        <RelativeLayout
            android:id="@+id/layout_sidebar_container"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceContainer">

            <laki.webide.core.html.HtmlSidebar
                android:id="@+id/html_sidebar"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Sidebar Toggle Button (Inside Sidebar Area) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_sidebar_toggle"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_margin="3dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_sidebar_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp"
                    android:src="@drawable/ic_mtrl_chevron_left_24"
                    app:tint="?attr/colorOnSurface"/>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>
       <!--<com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/linear18"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:singleSelection="true"
            app:selectionRequired="true"
            style="@style/Widget.Material3Expressive.MaterialButtonToggleGroup"
            tools:ignore="NotSibling">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/outline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editor"
                style="@style/Widget.Material3Expressive.Button.OutlinedButton"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fille"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview"
                android:textSize="12sp"
                style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
        </com.google.android.material.button.MaterialButtonToggleGroup> -->


        <!-- Block Workspace area (Canvas) -->
        <RelativeLayout
            android:id="@+id/block_workspace_root"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <RelativeLayout
                android:id="@+id/block_copy_interface"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSurface">

                <View
                    android:id="@+id/dim_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.5"
                    android:background="?attr/colorOnSurface"
                    android:visibility="gone" />

                <laki.webide.core.ViewLogicEditor
                    android:id="@+id/editor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="?attr/colorSurfaceVariant" >
                </laki.webide.core.ViewLogicEditor>
            </RelativeLayout>

            <!-- Trash can -->
            <ImageView
                android:id="@+id/icon_delete"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="24dp"
                android:contentDescription="@null"
                android:src="@drawable/icon_delete"
                android:translationY="66dp" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Dummy layer for dragging (Top level to cover sidebar and workspace) -->
    <laki.webide.core.ViewDummy
        android:id="@+id/dummy"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</RelativeLayout>
